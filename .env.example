# OpenRouter API Key
OPENROUTER_API_KEY=your_key_here

# PostgreSQL database connection string
DATABASE_URL=postgres://user:password@host:5432/database
# Set to false only for local PostgreSQL instances that do not use SSL
DATABASE_SSL=true

# WhatsApp Business API Credentials (from Meta Developers Console)
WHATSAPP_TOKEN=your_whatsapp_permanent_token_here
VERIFY_TOKEN=your_custom_verify_token_here

# Session secret for cookie encryption
SESSION_SECRET=change_this_to_a_random_32_plus_character_string
